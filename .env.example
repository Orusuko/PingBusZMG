# ═══════════════════════════════════════════════════════════════
# VíaSync ZMG — Variables de Entorno
# Copiar a .env y ajustar valores para tu entorno local.
# ═══════════════════════════════════════════════════════════════

# Conexión a PostgreSQL (ajustar usuario/password/host/puerto)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/viasync

# Salt para anonimización de UUIDs. Rotar diariamente en producción.
DAILY_SALT=cambiar_este_salt_cada_dia

# Velocidades promedio en metros/minuto
VEL_TREN=583.0
VEL_BUS=300.0

# Pool de conexiones asyncpg
DB_POOL_MIN=2
DB_POOL_MAX=10
